{% extends 'layout/front.html.twig' %}

{% block title %}Connexion — Sneakers Shop{% endblock %}

{% block main %}
    <h1>Connexion</h1>

    <form method="post" style="max-width: 360px;">
        {% if error %}
            <div class="flash flash-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <p>
            <label for="inputEmail">Email</label><br>
            <input type="email" value="{{ last_username }}" name="email" id="inputEmail" required autofocus style="width:100%; padding:0.4rem;">
        </p>
        <p>
            <label for="inputPassword">Mot de passe</label><br>
            <input type="password" name="password" id="inputPassword" required style="width:100%; padding:0.4rem;">
        </p>
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <button class="btn btn-primary" type="submit">Se connecter</button>
    </form>

    <p class="muted" style="margin-top:1rem;">Pas encore de compte ? <a href="{{ path('app_register') }}">Inscription</a></p>
{% endblock %}
