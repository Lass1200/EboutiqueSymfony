{% extends 'layout/admin.html.twig' %}

{% block title %}Ligne #{{ ligne_commande.id }}{% endblock %}

{% block main %}
    <h1>Ligne de commande #{{ ligne_commande.id }}</h1>
    <p><a href="{{ path('app_ligne_commande_index') }}">← Liste</a></p>

    <table class="table" style="max-width: 480px;">
        <tbody>
            <tr><th>Commande</th><td>{% if ligne_commande.commande %}<a href="{{ path('app_commande_show', {id: ligne_commande.commande.id}) }}">#{{ ligne_commande.commande.id }}</a>{% else %}—{% endif %}</td></tr>
            <tr><th>Produit</th><td>{% if ligne_commande.produit %}<a href="{{ path('app_produit_show', {id: ligne_commande.produit.id}) }}">{{ ligne_commande.produit.nom }}</a>{% else %}—{% endif %}</td></tr>
            <tr><th>Quantité</th><td>{{ ligne_commande.quantite }}</td></tr>
            <tr><th>Prix unitaire</th><td>{{ ligne_commande.prixUnitaire }} €</td></tr>
        </tbody>
    </table>

    <p><a href="{{ path('app_ligne_commande_edit', {id: ligne_commande.id}) }}">Modifier</a></p>
    {{ include('ligne_commande/_delete_form.html.twig') }}
{% endblock %}
