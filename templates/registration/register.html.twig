{% extends 'layout/front.html.twig' %}

{% block title %}Inscription — Sneakers Shop{% endblock %}

{% block main %}
    <h1>Créer un compte</h1>

    {{ form_errors(registrationForm) }}

    {{ form_start(registrationForm) }}
        {{ form_row(registrationForm.nom) }}
        {{ form_row(registrationForm.prenom) }}
        {{ form_row(registrationForm.email) }}
        {{ form_row(registrationForm.plainPassword, { label: 'Mot de passe' }) }}
        {{ form_row(registrationForm.agreeTerms, { label: 'J’accepte les conditions' }) }}
        <button type="submit" class="btn btn-primary">S’inscrire</button>
    {{ form_end(registrationForm) }}

    <p class="muted" style="margin-top:1rem;">Déjà inscrit ? <a href="{{ path('app_login') }}">Connexion</a></p>
{% endblock %}
